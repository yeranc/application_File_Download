<mvc:View
    controllerName="zal11.down.zfiledownload.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar">
    <Page title="{i18n>appTitle}">
        <subHeader>
            <OverflowToolbar>
                <Label text="{i18n>directory}:" required="true"/>
                <Input
                    width="20rem"
                    placeholder="/interface/Outbound"
                    value="{viewModel>/directory}"
                    class="sapUiSmallMarginEnd" />

                <Label text="{i18n>createdOn}:"/>
                <DatePicker
                    id="datePicker"
                    value="{viewModel>/createdOn}"
                    displayFormat="dd.MM.YYYY"
                    valueFormat="yyyy-MM-dd"
                    width="10rem"
                    class="sapUiSmallMarginEnd" />

                <Button
                    text="{i18n>goButton}"
                    type="Emphasized"
                    press="onSearch"/>

                <ToolbarSpacer/>

                <Button
                    text="{i18n>downloadButton}"
                    icon="sap-icon://download"
                    press="onDownload"/>
            </OverflowToolbar>
        </subHeader>

        <content>
            <smartTable:SmartTable
                id="smartTable"
                entitySet="FileDownloader"
                tableType="ResponsiveTable"
                useVariantManagement="true"
                useTablePersonalisation="true"
                app:p13nDialogSettings="{sort:{visible:true}, group:{visible:false}, filter:{visible:false}}"
                header="{i18n>files}"
                showRowCount="true"
                enableAutoBinding="false"
                demandPopin="true"
                class="sapUiResponsiveContentPadding">
            </smartTable:SmartTable>
        </content>
    </Page>
</mvc:View>